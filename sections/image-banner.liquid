{%- style -%}
  .banner.premium-hero {
    min-height: 80vh !important;
    background: var(--gradient-hero) !important;
    display: flex !important;
    align-items: center !important;
    padding: 120px 0 80px !important;
    position: relative;
    overflow: hidden;
  }

  .banner.premium-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 50% 20%, rgba(45, 90, 39, 0.05), transparent 50%);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .premium-hero .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .premium-hero .hero-content {
    text-align: left;
    z-index: 2;
  }

  .premium-hero.hero-centered .hero-grid {
    grid-template-columns: 1fr;
    max-width: 800px;
    margin: 0 auto;
  }

  .premium-hero.hero-centered .hero-content {
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    background: rgba(45, 90, 39, 0.05);
    border: 1px solid rgba(45, 90, 39, 0.1);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-brand-1);
    margin-bottom: 32px;
    animation: fadeInUp 0.8s ease forwards;
  }

  .hero-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--color-brand-1);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--color-brand-1);
  }

  .banner__heading {
    font-size: var(--text-hero) !important;
    font-weight: 800 !important;
    letter-spacing: -0.04em !important;
    line-height: 1.1 !important;
    color: var(--text-primary) !important;
    margin-bottom: 24px !important;
    animation: fadeInUp 0.8s ease 0.1s forwards;
    opacity: 0;
  }

  .banner__heading .highlight {
    background: var(--text-vibrant);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .banner__text {
    font-size: 20px !important;
    color: var(--text-secondary) !important;
    margin-bottom: 48px !important;
    line-height: 1.6 !important;
    animation: fadeInUp 0.8s ease 0.2s forwards;
    opacity: 0;
  }

  .banner__buttons {
    display: flex !important;
    gap: 16px !important;
    animation: fadeInUp 0.8s ease 0.3s forwards;
    opacity: 0;
  }

  .premium-hero.hero-centered .banner__buttons {
    justify-content: center;
  }

  .hero-image-container {
    position: relative;
    z-index: 1;
    animation: fadeInScale 1s ease 0.2s forwards;
    opacity: 0;
  }

  .hero-image-card {
    background: #ffffff;
    border-radius: 24px;
    padding: 12px;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.8);
    position: relative;
    overflow: hidden;
  }

  .hero-image-card img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    display: block;
  }

  .floating-element {
    position: absolute;
    background: #ffffff;
    border-radius: 16px;
    padding: 16px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    gap: 12px;
    z-index: 2;
    animation: floatY 4s ease-in-out infinite;
  }

  .floating-1 { top: 10%; left: -10%; animation-delay: 0s; }
  .floating-2 { bottom: 15%; right: -5%; animation-delay: 1s; }

  @media screen and (max-width: 989px) {
    .premium-hero .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }
    .premium-hero .hero-content {
      text-align: center;
    }
    .banner__buttons {
      justify-content: center;
    }
    .banner__heading {
      font-size: 48px !important;
    }
    .floating-element {
        display: none;
    }
  }
{%- endstyle -%}

<div id="Banner-{{ section.id }}" class="banner premium-hero {% if section.settings.image == blank %}hero-centered{% endif %}">
  <div class="page-width">
    <div class="hero-grid">
      <div class="hero-content">
        {%- if section.settings.hero_badge != blank -%}
          <div class="hero-badge">
            <span>{{ section.settings.hero_badge }}</span>
          </div>
        {%- endif -%}
        
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              <h1 class="banner__heading" {{ block.shopify_attributes }}>
                {{ block.settings.heading }}
              </h1>
            {%- when 'text' -%}
              <div class="banner__text" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {%- when 'buttons' -%}
              <div class="banner__buttons" {{ block.shopify_attributes }}>
                {%- if block.settings.button_label_1 != blank -%}
                  <a href="{{ block.settings.button_link_1 }}" class="button button--primary">
                    {{ block.settings.button_label_1 }} <span>→</span>
                  </a>
                {%- endif -%}
                {%- if block.settings.button_label_2 != blank -%}
                  <a href="{{ block.settings.button_link_2 }}" class="button button--secondary">
                    {{ block.settings.button_label_2 }}
                  </a>
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.image != blank -%}
        <div class="hero-image-container">
          <div class="hero-image-card">
            {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
          </div>
          
          <div class="floating-element floating-1">
            <div style="width: 32px; height: 32px; background: #f0f4f0; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #2d5a27;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <div>
              <div style="font-weight: 700; font-size: 14px; color: #1e291e;">Accurate Rates</div>
              <div style="font-size: 12px; color: #4a5a4a;">Real-time sync</div>
            </div>
          </div>

          <div class="floating-element floating-2">
             <div style="width: 32px; height: 32px; background: #f0f4f0; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #2d5a27;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            </div>
            <div>
              <div style="font-weight: 700; font-size: 14px; color: #1e291e;">Smart Packing</div>
              <div style="font-size: 12px; color: #4a5a4a;">AI 3D Logic</div>
            </div>
          </div>
        </div>
      {%- else -%}
        <div class="hero-image-container">
          <!-- Hero Mock UI: live checkout rates card -->
          <div class="hero-image-card" style="padding: 28px; background: #ffffff;">
            <!-- App Header -->
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid #f1f5f9;">
              <div style="width: 36px; height: 36px; background: #f0f4f0; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2d5a27" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
              </div>
              <div>
                <div style="font-weight: 800; font-size: 14px; color: #1e291e;">DimenAI</div>
                <div style="font-size: 11px; color: #64748b;">Shipping Rates</div>
              </div>
              <div style="margin-left: auto; background: #f0fdf0; color: #16a34a; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 20px; border: 1px solid #bbf7d0;">● Live</div>
            </div>

            <!-- Checkout rates -->
            <div style="font-size: 13px; font-weight: 700; color: #1e291e; margin-bottom: 12px;">Shipping Method</div>

            <!-- Rate 1 selected -->
            <div style="padding: 12px 14px; border: 2px solid #2d5a27; border-radius: 12px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; background: #f8faf8;">
              <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 16px; height: 16px; background: #2d5a27; border-radius: 50%; flex-shrink: 0;"></div>
                <div>
                  <div style="font-size: 13px; font-weight: 700; color: #1e291e;">UPS® Ground</div>
                  <div style="font-size: 11px; color: #64748b;">3–5 business days</div>
                </div>
              </div>
              <div style="font-weight: 800; font-size: 15px; color: #2d5a27;">$12.40</div>
            </div>

            <!-- Rate 2 -->
            <div style="padding: 12px 14px; border: 1.5px solid #f1f5f9; border-radius: 12px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
              <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 16px; height: 16px; border: 2px solid #e2e8f0; border-radius: 50%; flex-shrink: 0;"></div>
                <div>
                  <div style="font-size: 13px; font-weight: 600; color: #1e291e;">USPS Priority Mail</div>
                  <div style="font-size: 11px; color: #64748b;">1–3 business days</div>
                </div>
              </div>
              <div style="font-weight: 700; font-size: 14px; color: #475569;">$8.90</div>
            </div>

            <!-- Rate 3 -->
            <div style="padding: 12px 14px; border: 1.5px solid #f1f5f9; border-radius: 12px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
              <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 16px; height: 16px; border: 2px solid #e2e8f0; border-radius: 50%; flex-shrink: 0;"></div>
                <div>
                  <div style="font-size: 13px; font-weight: 600; color: #1e291e;">FedEx 2Day®</div>
                  <div style="font-size: 11px; color: #64748b;">2 business days</div>
                </div>
              </div>
              <div style="font-weight: 700; font-size: 14px; color: #475569;">$24.60</div>
            </div>

            <!-- Rate 4 -->
            <div style="padding: 12px 14px; border: 1.5px solid #f1f5f9; border-radius: 12px; display: flex; justify-content: space-between; align-items: center;">
              <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 16px; height: 16px; border: 2px solid #e2e8f0; border-radius: 50%; flex-shrink: 0;"></div>
                <div>
                  <div style="font-size: 13px; font-weight: 600; color: #1e291e;">Aus Post eParcel</div>
                  <div style="font-size: 11px; color: #64748b;">5–8 business days</div>
                </div>
              </div>
              <div style="font-weight: 700; font-size: 14px; color: #475569;">$18.20</div>
            </div>

            <!-- Packing badge -->
            <div style="margin-top: 16px; padding: 10px 14px; background: #f0fdf0; border-radius: 10px; display: flex; align-items: center; gap: 8px; border: 1px solid #bbf7d0;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
              <span style="font-size: 12px; font-weight: 600; color: #15803d;">AI packed into 1 box · 94% space efficiency</span>
            </div>
          </div>

          <!-- Floating badges -->
          <div class="floating-element floating-1">
            <div style="width: 32px; height: 32px; background: #f0f4f0; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #2d5a27; flex-shrink: 0;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <div>
              <div style="font-weight: 700; font-size: 13px; color: #1e291e;">Label Purchased</div>
              <div style="font-size: 11px; color: #4a5a4a;">Without leaving the app</div>
            </div>
          </div>

          <div class="floating-element floating-2">
            <div style="width: 32px; height: 32px; background: #f0f4f0; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #2d5a27; flex-shrink: 0;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            </div>
            <div>
              <div style="font-weight: 700; font-size: 13px; color: #1e291e;">3D Packed</div>
              <div style="font-size: 11px; color: #4a5a4a;">Optimal box selected</div>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image-banner.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "hero_badge",
      "label": "Hero Badge Text",
      "default": "Trusted by merchants worldwide"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image (Split Layout)"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Scale Your Store with Premium Solutions",
          "label": "Heading"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "default": "The ultimate Shopify app for merchants who demand high conversion.",
          "label": "Description"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Get Started",
          "label": "First Button Label"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "First Button Link"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "default": "View Demo",
          "label": "Second Button Label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Second Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image-banner.presets__1.name",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
