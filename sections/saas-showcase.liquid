{%- style -%}
  .saas-showcase {
    padding: var(--space-12) 0 !important;
    background: #f8faf8 !important; /* Subtle background for contrast */
  }
  .saas-showcase .collection__title {
    margin-bottom: 80px !important;
  }
  .saas-showcase .section-label {
    display: block;
    color: var(--color-brand-1) !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    margin-bottom: 16px !important;
  }
  .saas-showcase .title {
    font-size: 42px !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    color: var(--text-primary) !important;
  }

  .saas-showcase-item {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 80px !important;
    align-items: center !important;
    margin-bottom: 120px !important;
  }

  .saas-showcase-item:last-child {
    margin-bottom: 0 !important;
  }

  .saas-showcase-item.reverse {
    direction: rtl !important;
  }
  .saas-showcase-item.reverse .saas-showcase-content {
    direction: ltr !important;
  }

  .saas-showcase-image-wrapper {
    position: relative !important;
  }

  .saas-showcase-image {
    background: #ffffff !important;
    border-radius: 24px !important;
    padding: 12px !important;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08) !important;
    border: 1px solid rgba(0, 0, 0, 0.03) !important;
    overflow: hidden !important;
  }

  .saas-showcase-image img {
    width: 100% !important;
    height: auto !important;
    border-radius: 16px !important;
    display: block !important;
    transition: transform 0.6s ease;
  }

  .saas-showcase-item:hover .saas-showcase-image img {
    transform: scale(1.02);
  }

  .saas-showcase-content {
    max-width: 480px !important;
  }

  .saas-showcase-title {
    font-size: 32px !important;
    font-weight: 800 !important;
    color: var(--text-primary) !important;
    margin-bottom: 24px !important;
    line-height: 1.2 !important;
  }

  .saas-showcase-text {
    font-size: 18px !important;
    color: var(--text-secondary) !important;
    line-height: 1.7 !important;
    margin-bottom: 32px !important;
  }

  .saas-showcase-link {
    color: var(--color-brand-1) !important;
    font-weight: 700 !important;
    font-size: 16px !important;
    text-decoration: none !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 10px !important;
    transition: all 0.3s ease !important;
  }

  .saas-showcase-link span {
    transition: transform 0.3s ease;
  }

  .saas-showcase-link:hover {
    gap: 15px !important;
  }

  @media screen and (max-width: 989px) {
    .saas-showcase-item {
      grid-template-columns: 1fr !important;
      gap: 48px !important;
      text-align: center !important;
      margin-bottom: 80px !important;
    }
    .saas-showcase-item.reverse {
      direction: ltr !important;
    }
    .saas-showcase-content {
      max-width: 100% !important;
      margin: 0 auto !important;
    }
  }
{%- endstyle -%}

<section class="saas-showcase">
  <div class="page-width">
    <div class="collection__title center">
      <span class="section-label">Showcase</span>
      <h2 class="title">{{ section.settings.title }}</h2>
    </div>

    <div class="saas-showcase-items">
      {%- for block in section.blocks -%}
        <div class="saas-showcase-item {% cycle '', 'reverse' %}" {{ block.shopify_attributes }}>
          <div class="saas-showcase-image-wrapper">
            <div class="saas-showcase-image">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
              {%- else -%}
                <div style="aspect-ratio: 16/10; background: linear-gradient(135deg, #f0f4f0, #ffffff); display: flex; align-items: center; justify-content: center;">
                  <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.1"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                </div>
              {%- endif -%}
            </div>
          </div>
          <div class="saas-showcase-content">
            <h3 class="saas-showcase-title">{{ block.settings.title }}</h3>
            <div class="saas-showcase-text">{{ block.settings.text }}</div>
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link }}" class="saas-showcase-link">
                {{ block.settings.button_label }} <span>→</span>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS Showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Built for modern commerce",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "showcase",
      "name": "Showcase Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Feature Screenshot"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Feature Title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Explain the benefit of this feature in detail.</p>",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Learn More",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SaaS Showcase",
      "blocks": [
        { "type": "showcase" },
        { "type": "showcase" }
      ]
    }
  ]
}
{% endschema %}
