{%- style -%}
  .saas-showcase {
    padding: var(--space-12) 0 !important;
    background: #f8faf8 !important;
  }
  .saas-showcase .collection__title {
    margin-bottom: 80px !important;
  }
  .saas-showcase .section-label {
    display: block;
    color: var(--color-brand-1) !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    margin-bottom: 16px !important;
  }
  .saas-showcase .title {
    font-size: 42px !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    color: var(--text-primary) !important;
  }

  .saas-showcase-item {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 80px !important;
    align-items: center !important;
    margin-bottom: 120px !important;
  }

  .saas-showcase-item:last-child {
    margin-bottom: 0 !important;
  }

  .saas-showcase-item.reverse {
    direction: rtl !important;
  }
  .saas-showcase-item.reverse .saas-showcase-content {
    direction: ltr !important;
  }

  .saas-showcase-image-wrapper {
    position: relative !important;
  }

  /* Mock UI Styles */
  .mock-ui-container {
    background: #ffffff !important;
    border-radius: 24px !important;
    padding: 24px !important;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.08) !important;
    border: 1px solid rgba(0, 0, 0, 0.03) !important;
    overflow: hidden !important;
    width: 100% !important;
    aspect-ratio: 16/10 !important;
    position: relative;
  }

  /* Mock Checkout UI */
  .mock-checkout {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .mock-checkout-header {
    font-weight: 700;
    font-size: 16px;
    margin-bottom: 8px;
    color: #1e291e;
  }
  .mock-rate-item {
    padding: 12px;
    border: 1.5px solid #f0f4f0;
    border-radius: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .mock-rate-item.selected {
    border-color: var(--color-brand-1);
    background: #f0f4f0;
  }
  .mock-rate-name {
    font-size: 14px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .mock-rate-price {
    font-weight: 700;
    color: var(--color-brand-1);
  }

  /* Mock 3D Packing UI */
  .mock-3d-box {
    width: 200px;
    height: 120px;
    background: #e2e8e2;
    margin: 40px auto;
    position: relative;
    transform: rotateX(20deg) rotateY(-20deg);
    transform-style: preserve-3d;
    border: 2px solid #cbd5cb;
  }
  .mock-item {
    position: absolute;
    background: var(--color-brand-1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 10px;
    font-weight: 700;
  }

  /* Mock Carrier Account UI (Screenshot 3) */
  .mock-carrier-accounts {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 10px !important;
  }
  .carrier-account-field {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 10px;
    text-align: left;
  }
  .carrier-account-label {
    font-size: 10px;
    color: #64748b;
    margin-bottom: 4px;
    text-transform: uppercase;
    font-weight: 700;
  }
  .carrier-account-value {
    font-size: 12px;
    color: #1e293b;
    font-family: monospace;
  }

  /* Mock Package Management (Screenshot 5) */
  .mock-package-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .package-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px;
    background: #ffffff;
    border: 1px solid #f1f5f9;
    border-radius: 10px;
  }
  .package-info {
    text-align: left;
  }
  .package-name {
    font-weight: 700;
    font-size: 13px;
    color: #1e291e;
  }
  .package-dims {
    font-size: 11px;
    color: #64748b;
  }
  .add-box-btn {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-brand-1);
    background: #f0f4f0;
    padding: 4px 10px;
    border-radius: 6px;
  }

  .saas-showcase-content {
    max-width: 480px !important;
  }

  .saas-showcase-title {
    font-size: 32px !important;
    font-weight: 800 !important;
    color: var(--text-primary) !important;
    margin-bottom: 24px !important;
    line-height: 1.2 !important;
  }

  .saas-showcase-text {
    font-size: 18px !important;
    color: var(--text-secondary) !important;
    line-height: 1.7 !important;
    margin-bottom: 32px !important;
  }

  .saas-showcase-link {
    color: var(--color-brand-1) !important;
    font-weight: 700 !important;
    font-size: 16px !important;
    text-decoration: none !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 10px !important;
  }

  @media screen and (max-width: 989px) {
    .saas-showcase-item {
      grid-template-columns: 1fr !important;
      gap: 48px !important;
      text-align: center !important;
    }
    .saas-showcase-item.reverse {
      direction: ltr !important;
    }
  }
{%- endstyle -%}

<section class="saas-showcase">
  <div class="page-width">
    <div class="collection__title center">
      <span class="section-label">Showcase</span>
      <h2 class="title">{{ section.settings.title }}</h2>
    </div>

    <div class="saas-showcase-items">
      {%- for block in section.blocks -%}
        <div class="saas-showcase-item {% cycle '', 'reverse' %}" {{ block.shopify_attributes }}>
          <div class="saas-showcase-image-wrapper">
            {%- if block.settings.image != blank -%}
              <div class="mock-ui-container">
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', style: 'width: 100%; height: 100%; object-fit: cover; border-radius: 12px;' }}
              </div>
            {%- else -%}
              <div class="mock-ui-container">
                {%- case block.settings.mock_type -%}
                  {%- when 'checkout' -%}
                    <div class="mock-checkout">
                      <div class="mock-checkout-header">Shipping Method</div>
                      <div class="mock-rate-item selected">
                        <div class="mock-rate-name">
                          <div style="width: 20px; height: 20px; background: var(--color-brand-1); border-radius: 50%;"></div>
                          UPS® Ground
                        </div>
                        <div class="mock-rate-price">$12.40</div>
                      </div>
                      <div class="mock-rate-item">
                        <div class="mock-rate-name">
                          <div style="width: 20px; height: 20px; border: 1.5px solid #cbd5cb; border-radius: 50%;"></div>
                          FedEx International
                        </div>
                        <div class="mock-rate-price">$45.00</div>
                      </div>
                      <div class="mock-rate-item">
                        <div class="mock-rate-name">
                          <div style="width: 20px; height: 20px; border: 1.5px solid #cbd5cb; border-radius: 50%;"></div>
                          USPS Priority Mail
                        </div>
                        <div class="mock-rate-price">$8.90</div>
                      </div>
                    </div>
                  {%- when 'packing' -%}
                    <div class="mock-3d-box">
                      <div class="mock-item" style="width: 60px; height: 60px; top: 10px; left: 10px;">Item A</div>
                      <div class="mock-item" style="width: 40px; height: 40px; top: 10px; left: 80px; background: #8CB38D;">Item B</div>
                      <div class="mock-item" style="width: 100px; height: 30px; top: 80px; left: 10px; background: #5a8c5a;">Item C</div>
                    </div>
                    <div style="text-align: center; font-weight: 700; color: var(--color-brand-1); margin-top: 20px;">98% Space Efficiency</div>
                  {%- when 'dashboard' -%}
                    <div class="mock-carrier-accounts">
                      <div style="font-weight: 800; font-size: 14px; margin-bottom: 5px; color: #1e291e;">FedEx Account</div>
                      <div class="carrier-account-field">
                        <div class="carrier-account-label">Account Number</div>
                        <div class="carrier-account-value">740XXXXXXXX</div>
                      </div>
                      <div class="carrier-account-field">
                        <div class="carrier-account-label">Client ID</div>
                        <div class="carrier-account-value">l77XXXXXXXXXXXXXXXXX</div>
                      </div>
                      <div style="text-align: right; margin-top: 10px;">
                        <div style="display: inline-block; padding: 8px 16px; background: var(--color-brand-1); color: white; border-radius: 8px; font-size: 12px; font-weight: 700;">Save Settings</div>
                      </div>
                    </div>
                  {%- when 'packages' -%}
                    <div class="mock-package-list">
                      <div style="display: flex; gap: 10px; margin-bottom: 15px; border-bottom: 1px solid #f1f5f9; padding-bottom: 10px;">
                        <div style="font-weight: 700; font-size: 12px; color: var(--color-brand-1); border-bottom: 2px solid var(--color-brand-1);">UPS</div>
                        <div style="font-weight: 700; font-size: 12px; color: #64748b;">USPS</div>
                        <div style="font-weight: 700; font-size: 12px; color: #64748b;">FedEx</div>
                      </div>
                      <div class="package-item">
                        <div class="package-info">
                          <div class="package-name">UPS Small Express Box</div>
                          <div class="package-dims">13 x 11 x 2 in • max 70 lbs</div>
                        </div>
                        <div class="add-box-btn">Add Box</div>
                      </div>
                      <div class="package-item">
                        <div class="package-info">
                          <div class="package-name">UPS Medium Express Box</div>
                          <div class="package-dims">15 x 11 x 3 in • max 70 lbs</div>
                        </div>
                        <div class="add-box-btn">Add Box</div>
                      </div>
                    </div>
                {%- endcase -%}
              </div>
            {%- endif -%}
          </div>
          <div class="saas-showcase-content">
            <h3 class="saas-showcase-title">{{ block.settings.title }}</h3>
            <div class="saas-showcase-text">{{ block.settings.text }}</div>
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link }}" class="saas-showcase-link">
                {{ block.settings.button_label }} <span>→</span>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS Showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Built for modern commerce",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "showcase",
      "name": "Showcase Item",
      "settings": [
        {
          "type": "select",
          "id": "mock_type",
          "label": "Mock UI Type (If no image)",
          "options": [
            { "value": "checkout", "label": "Checkout Rates" },
            { "value": "packing", "label": "3D Bin Packing" },
            { "value": "dashboard", "label": "Carrier Dashboard" },
            { "value": "packages", "label": "Package Management" }
          ],
          "default": "checkout"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Feature Screenshot (Overrides Mock UI)"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Feature Title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Explain the benefit of this feature in detail.</p>",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Learn More",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SaaS Showcase",
      "blocks": [
        { "type": "showcase", "settings": { "mock_type": "checkout", "title": "Live Carrier Rates" } },
        { "type": "showcase", "settings": { "mock_type": "packing", "title": "AI 3D Bin Packing" } },
        { "type": "showcase", "settings": { "mock_type": "dashboard", "title": "Multi-Carrier Sync" } }
      ]
    }
  ]
}
{% endschema %}
