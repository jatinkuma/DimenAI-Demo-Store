{%- style -%}
  .saas-benefits {
    padding: var(--space-12) 0 !important;
    background: #ffffff !important;
    position: relative;
    overflow: hidden;
  }
  
  .saas-benefits::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(45, 90, 39, 0.03) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .saas-benefits-container {
    background: #ffffff !important;
    text-align: center !important;
    max-width: 1200px !important;
    margin: 0 auto !important;
  }
  .saas-benefits .title {
    font-size: 42px !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    margin-bottom: 64px !important;
    color: var(--text-primary) !important;
  }
  .saas-benefits-grid {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 40px !important;
  }
  .saas-benefit-item {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    padding: 40px 32px !important;
    background: #ffffff !important;
    border-radius: 24px !important;
    border: 1px solid #f1f5f9 !important;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }
  
  .saas-benefit-item:hover {
    background: #f8faf8 !important;
    border-color: rgba(45, 90, 39, 0.1) !important;
    transform: translateY(-5px) !important;
  }

  .saas-benefit-icon {
    width: 64px !important;
    height: 64px !important;
    background: #f0f4f0 !important;
    border-radius: 20px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin-bottom: 24px !important;
    color: var(--color-brand-1) !important;
    transition: all 0.3s ease;
  }
  
  .saas-benefit-item:hover .saas-benefit-icon {
    background: var(--color-brand-1) !important;
    color: #ffffff !important;
    transform: rotateY(180deg);
  }

  .saas-benefit-title {
    font-size: 20px !important;
    font-weight: 700 !important;
    color: var(--text-primary) !important;
    margin-bottom: 16px !important;
  }
  .saas-benefit-text {
    font-size: 16px !important;
    color: var(--text-secondary) !important;
    line-height: 1.6 !important;
    margin: 0 !important;
  }
  @media screen and (max-width: 989px) {
    .saas-benefits-grid {
      grid-template-columns: 1fr !important;
      gap: 24px !important;
    }
    .saas-benefit-item {
        padding: 32px !important;
    }
  }
{%- endstyle -%}

<section class="saas-benefits">
  <div class="page-width">
    <div class="saas-benefits-container">
      <h2 class="title">{{ section.settings.title }}</h2>
      
      <div class="saas-benefits-grid">
        {%- for block in section.blocks -%}
          <div class="saas-benefit-item" {{ block.shopify_attributes }}>
            <div class="saas-benefit-icon">
              {%- if block.settings.icon_svg != blank -%}
                {{ block.settings.icon_svg }}
              {%- else -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              {%- endif -%}
            </div>
            <h3 class="saas-benefit-title">{{ block.settings.title }}</h3>
            <p class="saas-benefit-text">{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS Benefits",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Why merchants love DimenAI",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Benefit Title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "default": "Explain the benefit to your customers.",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SaaS Benefits",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" }
      ]
    }
  ]
}
{% endschema %}
