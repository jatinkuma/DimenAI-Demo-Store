{%- style -%}
  .saas-benefits {
    padding: var(--space-12) 0 !important;
    background: #ffffff !important;
  }
  .saas-benefits-container {
    border: 1px solid #f1f5f9 !important;
    border-radius: 40px !important;
    padding: 80px !important;
    background: #ffffff !important;
    text-align: center !important;
    max-width: 1200px !important;
    margin: 0 auto !important;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.02) !important;
  }
  .saas-benefits .title {
    font-size: 36px !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    margin-bottom: 64px !important;
    color: var(--text-primary) !important;
  }
  .saas-benefits-grid {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 48px !important;
  }
  .saas-benefit-item {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
  }
  .saas-benefit-icon {
    width: 48px !important;
    height: 48px !important;
    background: #f0f4f0 !important;
    border-radius: 12px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin-bottom: 24px !important;
    color: #2d5a27 !important;
  }
  .saas-benefit-title {
    font-size: 18px !important;
    font-weight: 700 !important;
    color: var(--text-primary) !important;
    margin-bottom: 12px !important;
  }
  .saas-benefit-text {
    font-size: 15px !important;
    color: var(--text-secondary) !important;
    line-height: 1.6 !important;
    margin: 0 !important;
  }
  @media screen and (max-width: 989px) {
    .saas-benefits-container {
      padding: 40px !important;
    }
    .saas-benefits-grid {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
  }
{%- endstyle -%}

<section class="saas-benefits">
  <div class="page-width">
    <div class="saas-benefits-container">
      <h2 class="title">Why merchants love DimenAI</h2>
      
      <div class="saas-benefits-grid">
        <div class="saas-benefit-item">
          <div class="saas-benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
          </div>
          <h3 class="saas-benefit-title">Accurate Rates</h3>
          <p class="saas-benefit-text">Fetch real-time rates from UPS, USPS, FedEx, and Australia Post to ensure you never undercharge for shipping.</p>
        </div>

        <div class="saas-benefit-item">
          <div class="saas-benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
          </div>
          <h3 class="saas-benefit-title">Save on Packaging</h3>
          <p class="saas-benefit-text">Our AI 3D bin packing ensures you use the smallest possible box, saving on dimensional weight costs.</p>
        </div>

        <div class="saas-benefit-item">
          <div class="saas-benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <h3 class="saas-benefit-title">Streamlined Workflow</h3>
          <p class="saas-benefit-text">Manage boxes, review orders, and buy labels all in one place for a faster fulfillment process.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS Benefits",
  "tag": "section",
  "class": "section",
  "presets": [
    {
      "name": "SaaS Benefits"
    }
  ]
}
{% endschema %}
