{%- style -%}
  .saas-cta {
    padding: var(--space-12) 0 !important;
    background: #ffffff !important;
  }
  .saas-cta-container {
    background: var(--gradient-vibrant) !important;
    border-radius: 40px !important;
    padding: 100px 40px !important;
    margin: 0 40px !important;
    text-align: center !important;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(45, 90, 39, 0.2) !important;
  }
  .saas-cta-container::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(255, 255, 255, 0.1), transparent 60%);
    pointer-events: none;
  }
  .saas-cta-heading {
    color: #ffffff !important;
    font-size: 56px !important;
    font-weight: 800 !important;
    letter-spacing: -0.04em !important;
    margin-bottom: 24px !important;
    line-height: 1.1 !important;
    position: relative;
    z-index: 2;
  }
  .saas-cta-text {
    color: rgba(255, 255, 255, 0.9) !important;
    font-size: 20px !important;
    max-width: 600px !important;
    margin: 0 auto 48px !important;
    line-height: 1.6 !important;
    position: relative;
    z-index: 2;
  }
  .button--cta {
    background: #ffffff !important;
    color: #2d5a27 !important;
    border-radius: var(--radius-pill) !important;
    padding: 20px 48px !important;
    font-weight: 700 !important;
    font-size: 18px !important;
    text-decoration: none !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 12px !important;
    transition: var(--transition-spring) !important;
    position: relative;
    z-index: 2;
  }
  .button--cta:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }
  @media screen and (max-width: 749px) {
    .saas-cta-container {
      margin: 0 20px !important;
      padding: 60px 24px !important;
    }
    .saas-cta-heading {
      font-size: 36px !important;
    }
  }
{%- endstyle -%}

<section class="saas-cta">
  <div class="page-width">
    <div class="saas-cta-container">
      <h2 class="saas-cta-heading">{{ section.settings.title }}</h2>
      <p class="saas-cta-text">{{ section.settings.text }}</p>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button--cta">
          {{ section.settings.button_label }} <span>→</span>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS CTA Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Ready to Transform Your Store?",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "default": "Join 2,000+ Shopify Plus merchants scaling their business with our premium solution.",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Start Free Trial",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "SaaS CTA Section"
    }
  ]
}
{% endschema %}
